# Base URL for the FastAPI backend. In dev, leave blank to use the Vite proxy
# (see vite.config.ts), or set the full origin for a deployed backend.
VITE_API_BASE_URL=

# Microsoft Entra ID (sign-in). Same tenant + client id the backend validates
# against (AZURE_TENANT_ID / AZURE_CLIENT_ID in the backend .env). The app
# registration must list this origin (e.g. http://localhost:5173) as an SPA
# redirect URI. Put real values in a gitignored .env.local.
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=

# Local-dev auth bypass. Set VITE_DEV_AUTH=true to skip the Microsoft login and
# send a hardcoded developer token instead of a real Entra ID token. The backend
# must run with DEV_AUTH=true (and a matching DEV_AUTH_TOKEN). Leave OFF/unset in
# any deployed environment.
VITE_DEV_AUTH=false
VITE_DEV_AUTH_TOKEN=dev-local-token
